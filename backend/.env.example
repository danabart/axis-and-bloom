PORT=4000
NODE_ENV=development

# PostgreSQL (Cloud SQL)
DATABASE_URL=postgresql://user:password@localhost:5432/axisandbloom

# Firebase Admin (service account JSON as string, or path)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Shopify (roastery store)
SHOPIFY_STORE_DOMAIN=your-roastery.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
SHOPIFY_ADMIN_TOKEN=your-admin-access-token

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
